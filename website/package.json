{
  "name": "docus-starter",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "start": "pnpm run build:types && nuxt dev --extends docus",
    "clean": "rm -rf .nuxt .data .output dist",
    "dev": "nuxt dev --extends docus",
    "dev:fresh": "pnpm run clean && pnpm run dev",
    "build": "pnpm run build:types && nuxt build --extends docus",
    "build:types": "cd .. && pnpm run build",
    "check-links": "pnpm exec tsx scripts/check-links.ts",
    "check-unused-examples": "pnpm exec tsx scripts/check-unused-examples.ts",
    "test": "pnpm exec playwright test",
    "test:ui": "pnpm exec playwright test --ui",
    "generate": "nuxt generate --extends docus",
    "preview": "pnpm exec serve .output/public"
  },
  "dependencies": {
    "@nuxt/content": "3.12.0",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/image": "1.11.0",
    "@nuxt/scripts": "0.13.2",
    "@nuxt/ui": "4.6.1",
    "@shikijs/twoslash": "3.23.0",
    "@unhead/vue": "2.1.13",
    "better-sqlite3": "12.8.0",
    "billboard.js": "3.18.0",
    "docus": "5.9.0",
    "eslint": "9.39.4",
    "mermaid": "11.14.0",
    "nuxt": "4.4.2",
    "shiki": "3.23.0",
    "twoslash-vue": "0.3.7",
    "typescript": "5.9.3",
    "vue-writer": "2.0.2"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1"
  }
}
