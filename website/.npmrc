# ─────────────────────────────────────────────────────────
# Mion website — pnpm security-hardened configuration
# ─────────────────────────────────────────────────────────

# ── Lockfile / install integrity ─────────────────────────
frozen-lockfile=true
prefer-frozen-lockfile=true
verify-store-integrity=true

# ── Version pinning ──────────────────────────────────────
save-exact=true
save-prefix=
resolution-mode=highest

# ── Supply-chain protection: minimum release age ─────────
# 30 days — same policy as root.
minimum-release-age=43200
minimum-release-age-exclude=

# ── Block lifecycle scripts ──────────────────────────────
# pnpm 10 blocks all build scripts by default. The explicit allowlist of
# packages permitted to run install/postinstall scripts lives in
# `pnpm-workspace.yaml -> onlyBuiltDependencies`. Setting
# `ignore-scripts=true` here would block even the allowlisted packages,
# so we leave the default (false) and rely on the allowlist for safety.
ignore-scripts=false

# ── Block non-registry sources ───────────────────────────
registry=https://registry.npmjs.org/
allow-non-registry-protocols=false

# ── Strict peer / hoisting ───────────────────────────────
strict-peer-dependencies=false
auto-install-peers=false
node-linker=isolated

# ── Misc hardening ───────────────────────────────────────
fund=false
audit=false
loglevel=warn
