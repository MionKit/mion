{
  "name": "mionkit",
  "description": "mion is framework to build full stack APIs at the speed of light",
  "version": "0.1.0",
  "type": "module",
  "main": "index.js",
  "homepage": "https://github.com/MionKit/mion#readme",
  "scripts": {
    "test": "lerna run test",
    "format": "prettier --write packages/**/*.{ts,md}",
    "check-format": "prettier --check packages/**/*.{ts,md}",
    "check-format-pre-commit": "prettier --check",
    "lint": "lerna run lint",
    "lint-pre-committ": "eslint --quiet --ignore-pattern **/eslint-rule-test.routes.ts",
    "build": "lerna run build",
    "build-ts-dts": "npm run clean && lerna run build-ts-dts",
    "clean": "lerna run clean; nx reset --onlyCache && jest --clearCache",
    "fresh-start": "lerna run fresh-start && rimraf node_modules",
    "deepkit-install": "deepkit-type-install",
    "npm-publish": "lerna publish from-package --no-private",
    "prepare": "husky install",
    "copy-benchmarks": "cp -r ../mion-benchmarks/assets/public/* ./website/app/components/content/charts/ && node scripts/copy-benchmarks.js"
  },
  "lint-staged": {
    "packages/!(examples)/**/!(*.spec|*.test).ts": [
      "npm run lint-pre-committ --",
      "npm run check-format-pre-commit --"
    ],
    "packages/!(examples)/**/*.{spec,test}.ts": [
      "npm run check-format-pre-commit --"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com:MionKit/mion.git"
  },
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node"
  ],
  "author": "ma-jerez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MionKit/issues"
  },
  "engines": {
    "node": ">= 24.0.0"
  },
  "devDependencies": {
    "@deepkit/core": "1.0.19",
    "@deepkit/type-compiler": "1.0.19",
    "@deepkit/vite": "^1.0.19",
    "@mionkit/eslint-plugin": "file:./packages/eslint-plugin",
    "@playwright/mcp": "^0.0.56",
    "@types/aws-lambda": "^8.10.108",
    "@types/jest": "^29.5.3",
    "@types/node": "^18.17.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^8.46.0",
    "eslint-plugin-jest": "^29.0.1",
    "husky": "^8.0.1",
    "jest": "^29.6.2",
    "lerna": "^6.4.1",
    "lint-staged": "^16.2.4",
    "nx": "22.4.4",
    "prettier": "^3.0.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.1.9"
  },
  "workspaces": [
    "packages/aot-caches",
    "packages/aws",
    "packages/test-publish",
    "packages/bun",
    "packages/client",
    "packages/codegen",
    "packages/core",
    "packages/drizze",
    "packages/eslint-plugin",
    "packages/type-formats",
    "packages/gcloud",
    "packages/node",
    "packages/quick-start",
    "packages/router",
    "packages/run-types",
    "packages/server-pure-functions",
    "packages/test-server"
  ],
  "dependencies": {
    "typescript": "5.9.3"
  }
}
