{
  "name": "mionkit",
  "description": "mion is framework to build full stack APIs at the speed of light",
  "version": "0.1.0",
  "type": "module",
  "main": "index.js",
  "homepage": "https://github.com/MionKit/mion#readme",
  "scripts": {
    "test": "vitest run",
    "format": "prettier --write 'packages/**/*.{ts,md}'",
    "check-format": "prettier --check 'packages/**/*.{ts,md}'",
    "check-format-pre-commit": "prettier --check",
    "lint": "lerna run lint",
    "lint:spec": "npx eslint --fix packages/**/*.spec.ts",
    "lint-pre-committ": "npx eslint --quiet --ignore-pattern **/eslint-rule-test.routes.ts",
    "build": "lerna run build",
    "clean": "lerna run clean",
    "fresh-start": "lerna run fresh-start && rimraf node_modules",
    "deepkit-install": "deepkit-type-install",
    "pre-publish-test": "bash scripts/pre-publish-test.sh",
    "npm-publish": "lerna publish from-package --no-private",
    "prepare": "husky install",
    "copy-benchmarks": "cp -r ../mion-benchmarks/assets/public/* ./website/app/components/content/charts/ && node scripts/copy-benchmarks.js",
    "pages-build": "npm run build && cd website && npm ci && npm run generate"
  },
  "lint-staged": {
    "packages/!(examples)/**/!(*.spec|*.test).ts": [
      "npm run lint-pre-committ --",
      "npm run check-format-pre-commit --"
    ],
    "packages/!(examples)/**/*.{spec,test}.ts": [
      "npm run check-format-pre-commit --"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com:MionKit/mion.git"
  },
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node"
  ],
  "author": "ma-jerez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MionKit/issues"
  },
  "engines": {
    "node": ">= 24.0.0"
  },
  "devDependencies": {
    "@deepkit/core": "1.0.19",
    "@deepkit/type-compiler": "1.0.19",
    "@edge-runtime/vm": "^5.0.0",
    "miniflare": "^3.20241106.1",
    "@playwright/mcp": "^0.0.56",
    "@types/aws-lambda": "^8.10.108",
    "@types/node": "^24.0.0",
    "eslint": "^9.20.1",
    "husky": "^8.0.1",
    "lerna": "^6.4.1",
    "nx": "22.4.4",
    "lint-staged": "^16.2.4",
    "prettier": "^3.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^7.3.1",
    "vite-node": "^5.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "workspaces": [
    "packages/platform-aws",
    "packages/platform-bun",
    "packages/client",
    "packages/devtools",
    "packages/core",
    "packages/drizze",
    "packages/type-formats",
    "packages/platform-gcloud",
    "packages/platform-node",
    "packages/router",
    "packages/run-types",
    "packages/test-server",
    "packages/platform-vercel",
    "packages/platform-cloudflare"
  ],
  "dependencies": {
    "typescript": "5.9.3"
  }
}
