{
  "name": "mionkit",
  "description": "mion is framework to build full stack APIs at the speed of light",
  "version": "0.1.0",
  "type": "module",
  "main": "index.js",
  "homepage": "https://github.com/MionKit/mion#readme",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "test": "vitest run",
    "test:ci": "vitest run --project core --project run-types --project router --project type-formats && vitest run --project drizze --project devtools --project platform-aws --project platform-gcloud && vitest run --project platform-node --project platform-vercel --project platform-cloudflare && vitest run --project client",
    "format": "prettier --write 'packages/**/*.{ts,md}'",
    "check-format": "prettier --check 'packages/**/*.{ts,md}'",
    "check-format-pre-commit": "prettier --check",
    "lint": "lerna run lint",
    "lint:spec": "eslint --fix packages/**/*.spec.ts",
    "lint-pre-committ": "eslint --quiet --ignore-pattern **/eslint-rule-test.routes.ts",
    "build": "lerna run build",
    "clean": "nx reset && lerna run clean",
    "fresh-start": "lerna run fresh-start && rimraf node_modules && pnpm install --frozen-lockfile && pnpm --filter @mionjs/devtools run build",
    "pre-publish-test": "bash scripts/pre-publish-test.sh",
    "npm-publish": "bash scripts/publish.sh",
    "npm-unpublish": "bash scripts/unpublish.sh",
    "prepare": "husky",
    "copy-benchmarks": "cp -r ../mion-benchmarks/assets/public/* ./website/app/components/content/charts/ && node scripts/copy-benchmarks.js",
    "pages-build": "pnpm run build && cd website && pnpm install --frozen-lockfile && pnpm run generate"
  },
  "lint-staged": {
    "packages/!(examples)/**/!(*.spec|*.test|vite.config|vite.*.config|vitest.config).ts": [
      "pnpm run lint-pre-committ --",
      "pnpm run check-format-pre-commit --"
    ],
    "packages/!(examples)/**/*.{spec,test}.ts": [
      "pnpm run check-format-pre-commit --"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com:MionKit/mion.git"
  },
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node"
  ],
  "author": "ma-jerez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MionKit/issues"
  },
  "engines": {
    "node": ">= 24.0.0",
    "pnpm": ">= 11.0.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "5.0.0",
    "@eslint/js": "9.39.4",
    "@mionjs/devtools": "workspace:*",
    "@playwright/mcp": "0.0.56",
    "@types/aws-lambda": "8.10.161",
    "@types/node": "24.12.2",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "lerna": "9.0.7",
    "lint-staged": "16.4.0",
    "miniflare": "3.20250718.3",
    "nx": "22.4.4",
    "prettier": "3.8.2",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript-eslint": "8.58.1",
    "vite": "7.3.2",
    "vite-node": "5.3.0",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.4"
  },
  "dependencies": {
    "typescript": "6.0.2"
  }
}
