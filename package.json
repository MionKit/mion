{
  "name": "mionkit",
  "description": "mion is framework to build full stack APIs at the speed of light",
  "version": "0.1.0",
  "main": "index.js",
  "homepage": "https://github.com/MionKit/mion#readme",
  "scripts": {
    "test": "lerna run test",
    "format": "prettier --write packages/**/*.{ts,md}",
    "check-format-pre-commit": "CI=true prettier --check",
    "lint": "lerna run lint",
    "lint-pre-committ": "CI=true eslint --quiet",
    "build": "lerna run build",
    "clean": "lerna run clean  && nx reset && jest --clearCache",
    "fresh-start": "lerna run fresh-start && rimraf node_modules",
    "deepkit-install": "deepkit-type-install",
    "auto-readme": "embedme README.md && lerna run auto-readme",
    "npm-publish": "lerna publish from-package --no-private",
    "prepare": "husky install"
  },
  "lint-staged": {
    "packages/**/*.ts": [
      "npm run lint-pre-committ --",
      "npm run check-format-pre-commit --"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com:MionKit/mion.git"
  },
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node"
  ],
  "author": "ma-jerez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MionKit/issues"
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "devDependencies": {
    "@deepkit/core": "1.0.1",
    "@deepkit/type-compiler": "1.0.2",
    "@mionkit/eslint-plugin": "file:./packages/eslint-plugin",
    "@types/aws-lambda": "^8.10.108",
    "@types/jest": "^29.5.3",
    "@types/node": "^18.17.0",
    "@types/prettier": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "embedme": "^1.22.1",
    "eslint": "^8.46.0",
    "eslint-plugin-jest": "^29.0.1",
    "husky": "^8.0.1",
    "jest": "^29.6.2",
    "lerna": "7.1.5",
    "lint-staged": "^16.2.4",
    "nx": ">=16.5.1 < 17",
    "prettier": "^3.0.1",
    "ts-jest": "^29.1.1"
  },
  "workspaces": [
    "packages/aws",
    "packages/bun",
    "packages/client",
    "packages/codegen",
    "packages/core",
    "packages/eslint-plugin",
    "packages/formats",
    "packages/gcloud",
    "packages/http",
    "packages/quick-start",
    "packages/router",
    "packages/run-types"
  ],
  "dependencies": {
    "typescript": "^5.3.3"
  }
}
