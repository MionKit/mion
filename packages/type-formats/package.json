{
  "name": "@mionkit/type-formats",
  "version": "0.7.2",
  "type": "module",
  "description": "mion standard linkedFns and routes",
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node",
    "runtime types",
    "deepkit"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "browser": {},
  "exports": {
    "./FormatsNumber": {
      "types": "./.dist/esm/FormatsNumber.d.ts",
      "require": "./.dist/cjs/FormatsNumber.js",
      "default": "./.dist/esm/FormatsNumber.js"
    },
    "./FormatsString": {
      "types": "./.dist/esm/FormatsString.d.ts",
      "require": "./.dist/cjs/FormatsString.js",
      "default": "./.dist/esm/FormatsString.js"
    },
    "./FormatsBigint": {
      "types": "./.dist/esm/FormatsBigint.d.ts",
      "require": "./.dist/cjs/FormatsBigint.js",
      "default": "./.dist/esm/FormatsBigint.js"
    },
    "./index": {
      "types": "./.dist/esm/index.d.ts",
      "require": "./.dist/cjs/index.js",
      "default": "./.dist/esm/index.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite build --watch",
    "dev:test": "vitest watch",
    "lint": "npx --node-options='--experimental-strip-types' eslint --flag unstable_native_nodejs_ts_config src",
    "format": "prettier --write src/**/*.ts",
    "build": "vite build",
    "build-ts-dts": "tsc --project tsconfig.json --emitDeclarationOnly --declaration --skipLibCheck --outDir .dist/esm",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@mionkit/core": "^0.7.2",
    "@mionkit/run-types": "0.7.2"
  }
}
