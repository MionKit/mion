{
  "name": "@mionkit/bun",
  "version": "0.7.2",
  "description": "mion server for bun runtime",
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node",
    "runtime types",
    "deepkit"
  ],
  "author": "ma jerez <jerez.m82@gmail.com>",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./.dist/esm/index.d.ts",
      "require": "./.dist/cjs/index.js",
      "default": "./.dist/esm/index.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.0.1"
  },
  "scripts": {
    "test": "bun test",
    "dev": "vite build --watch",
    "dev:test": "bun test --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "build": "vite build",
    "build-ts-dts": "tsc --project tsconfig.json --emitDeclarationOnly --declaration --skipLibCheck --outDir .dist/esm",
    "auto-readme": "embedme **/*.md && prettier --write **/*.md",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@mionkit/core": "^0.7.2",
    "@mionkit/router": "^0.7.2"
  },
  "devDependencies": {
    "@deepkit/core": "1.0.19",
    "@deepkit/type-compiler": "1.0.19",
    "bun-types": "latest"
  }
}
