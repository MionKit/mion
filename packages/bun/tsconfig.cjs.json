{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": [],
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": ".dist/cjs",
    "types": ["bun-types"],
    "composite": true
  },
  "reflection": true,
  "include": ["."],
  "exclude": ["node_modules", "loader", "**/*.spec.ts", "**/*.test.ts", ".dist"]
}
