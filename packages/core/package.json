{
  "name": "@mionjs/core",
  "version": "0.8.4",
  "type": "module",
  "description": "Core functionality required across multiple mion packages",
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node",
    "runtime types"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "browser": {},
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./.dist/esm/index.d.ts",
      "require": "./.dist/cjs/index.cjs",
      "default": "./.dist/esm/index.js"
    },
    "./aot-caches": {
      "source": "./src/aot/aotCaches.ts",
      "types": "./.dist/esm/src/aot/aotCaches.d.ts",
      "require": "./.dist/cjs/src/aot/aotCaches.cjs",
      "default": "./.dist/esm/src/aot/aotCaches.js"
    },
    "./server-pure-fns": {
      "source": "./src/aot/serverPureFnsCaches.ts",
      "types": "./.dist/esm/src/aot/serverPureFnsCaches.d.ts",
      "require": "./.dist/cjs/src/aot/serverPureFnsCaches.cjs",
      "default": "./.dist/esm/src/aot/serverPureFnsCaches.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite build --watch",
    "dev:test": "vitest watch",
    "lint": "npx eslint src",
    "format": "prettier --write src/**/*.ts",
    "build": "vite build",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "gitHead": "afd6e1d61525b4bf11bb84b3f85089038d70062d"
}
