{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "noImplicitAny": false,
    "removeComments": true,
    "noLib": false,
    "strict": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "outDir": ".dist",
    "declaration": false,
    "sourceMap": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["."],
  "exclude": ["node_modules", ".dist"]
}
