{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": ".dist/types",
    "composite": true,
    "rootDir": ".",
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true
  },
  "references": [{"path": "../core"}],
  "reflection": true,
  "include": ["."],
  "exclude": [
    "node_modules",
