{
  "name": "@mionkit/run-types",
  "version": "0.7.2",
  "description": "Run time functionality directly from typescript types",
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node",
    "runtime types",
    "deepkit"
  ],
  "author": "ma jerez <jerez.m82@gmail.com>",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "browser": {
    "./persist/jitFnCacheCompiler": false
  },
  "exports": {
    ".": {
      "types": "./.dist/esm/index.d.ts",
      "require": "./.dist/cjs/index.js",
      "default": "./.dist/esm/index.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "jest",
    "dev": "vite build --watch",
    "dev:test": "jest --watch",
    "lint": "eslint src --ext .ts --ignore-pattern xyzSpec",
    "format": "prettier --write src/**/*.ts",
    "build": "vite build",
    "build-ts-dts": "tsc --project tsconfig.json --emitDeclarationOnly --declaration --skipLibCheck --outDir .dist/esm",
    "auto-readme": "embedme **/*.md && prettier --write **/*.md",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@deepkit/core": "1.0.19",
    "@deepkit/type": "1.0.19",
    "@mionkit/core": "^0.7.2"
  },
  "gitHead": "2efdcd77c572e64f2b9621b4921ffd2f5e83bc0a"
}
