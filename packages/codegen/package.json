{
  "name": "@mionkit/codegen",
  "version": "0.7.2",
  "type": "module",
  "description": "Ahead-of-time code generation for mion run-types and router caches.",
  "keywords": [
    "typescript",
    "codegen",
    "code-generation",
    "AOT",
    "ahead-of-time",
    "compilation",
    "run-types",
    "router",
    "cache",
    "mion"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./.dist/esm/index.d.ts",
      "require": "./.dist/cjs/index.js",
      "default": "./.dist/esm/index.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist",
    "mion-aot-template",
    "bin"
  ],
  "bin": {
    "mion-init-aot": "./bin/mion-init-aot.js",
    "mion-build-aot": "./bin/mion-build-aot.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite build --watch",
    "dev:test": "vitest watch",
    "lint": "npx --node-options='--experimental-strip-types' eslint --flag unstable_native_nodejs_ts_config src",
    "format": "prettier --write src/**/*.ts",
    "build": "npm run build:aot-template && vite build",
    "build-ts-dts": "echo 'noop: codegen uses custom build'",
    "build:aot-template": "cd mion-aot-template && npm run build",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@mionkit/core": "^0.7.2",
    "@mionkit/router": "^0.7.2",
    "@mionkit/run-types": "^0.7.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "typescript": "^5.0.0"
  }
}
