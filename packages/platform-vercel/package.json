{
  "name": "@mionjs/platform-vercel",
  "version": "0.8.10",
  "type": "module",
  "description": "mion adapter for Vercel serverless functions",
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "server",
    "serverless",
    "framework",
    "vercel"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./.dist/esm/index.d.ts",
      "require": "./.dist/cjs/index.cjs",
      "default": "./.dist/esm/index.js"
    },
    "./dev-server": {
      "source": "./src/devServer.ts",
      "types": "./.dist/esm/src/devServer.d.ts",
      "require": "./.dist/cjs/src/devServer.cjs",
      "default": "./.dist/esm/src/devServer.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist",
    "index.ts",
    "src",
    "!src/**/*.spec.ts",
    "!src/**/*.test.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite build --watch",
    "dev:test": "vitest watch",
    "lint": "eslint src",
    "format": "prettier --write src/**/*.ts",
    "build": "vite build",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "pnpm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@mionjs/core": "workspace:*",
    "@mionjs/router": "workspace:*"
  },
  "gitHead": "afd6e1d61525b4bf11bb84b3f85089038d70062d"
}
