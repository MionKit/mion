{
  "name": "@mionjs/drizzle",
  "version": "0.8.7",
  "type": "module",
  "description": "drizzle extension for mion run-types",
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "browser": {},
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./.dist/esm/index.d.ts",
      "default": "./.dist/esm/index.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite build --watch",
    "dev:test": "vitest watch",
    "lint": "npx eslint src",
    "format": "prettier --write src/**/*.ts",
    "build": "vite build",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@mionjs/core": "0.8.7",
    "@mionjs/run-types": "0.8.7",
    "@mionjs/type-formats": "0.8.7",
    "drizzle-orm": "^0.38.0"
  },
  "gitHead": "afd6e1d61525b4bf11bb84b3f85089038d70062d"
}
