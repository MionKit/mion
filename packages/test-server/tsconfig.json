{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": ".dist/esm",
    "composite": true,
    "rootDir": ".",
    "baseUrl": "..",
    "module": "nodeNext",
    "moduleResolution": "nodeNext",
    "types": ["@mionjs/devtools/virtual-modules", "@types/node"],
    "paths": {
      "@mionjs/core": ["core/index.ts"],
      "@mionjs/router": ["router/index.ts"],
      "@mionjs/platform-node": ["node/index.ts"],
      "@mionjs/platform-cloudflare": ["platform-cloudflare/index.ts"],
      "@mionjs/platform-vercel": ["platform-vercel/index.ts"],
      "@mionjs/type-formats": ["type-formats/index.ts"],
      "@mionjs/type-formats/*": ["type-formats/*"],
      "@mionjs/run-types": ["run-types/index.ts"]
    }
  },
  "ts-node": {
    "esm": true
  },
  "references": [
    {"path": "../core"},
    {"path": "../router"},
    {"path": "../platform-node"},
    {"path": "../platform-cloudflare"},
    {"path": "../platform-vercel"},
    {"path": "../type-formats"},
    {"path": "../run-types"}
  ],
  "reflection": true,
  "include": ["."],
  "exclude": ["node_modules", ".dist", "build", "vite.config.ts", "vite.edge.config.ts", "vite.cloudflare.config.ts"]
}
