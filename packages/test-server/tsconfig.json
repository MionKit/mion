{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": ".dist/esm",
    "composite": true,
    "rootDir": ".",
    "baseUrl": "..",
    "paths": {
      "@mionkit/core": ["core/index.ts"],
      "@mionkit/router": ["router/index.ts"],
      "@mionkit/node": ["node/index.ts"],
      "@mionkit/type-formats": ["type-formats/index.ts"],
      "@mionkit/type-formats/*": ["type-formats/*"],
      "@mionkit/run-types": ["run-types/index.ts"]
    }
  },
  "references": [
    {"path": "../core"},
    {"path": "../router"},
    {"path": "../node"},
    {"path": "../type-formats"},
    {"path": "../run-types"}
  ],
  "reflection": true,
  "include": ["."],
  "exclude": ["node_modules", ".dist", "vite.config.ts"]
}
