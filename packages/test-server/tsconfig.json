{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": ".dist/esm",
    "composite": true,
    "rootDir": ".",
    "module": "nodeNext",
    "moduleResolution": "nodeNext",
    "types": ["@mionjs/devtools/virtual-modules", "@types/node"],
    "paths": {
      "@mionjs/core": ["../core/index.ts"],
      "@mionjs/router": ["../router/index.ts"],
      "@mionjs/platform-node": ["../platform-node/index.ts"],
      "@mionjs/platform-cloudflare": ["../platform-cloudflare/index.ts"],
      "@mionjs/platform-vercel": ["../platform-vercel/index.ts"]
    }
  },
  "ts-node": {
    "esm": true
  },
  "references": [
    {"path": "../core"},
    {"path": "../router"},
    {"path": "../platform-node"},
    {"path": "../platform-cloudflare"},
    {"path": "../platform-vercel"}
    
  ],
  "include": ["."],
  "exclude": ["node_modules", ".dist", "build", "vite.config.ts", "vite.edge.config.ts", "vite.cloudflare.config.ts"]
}
