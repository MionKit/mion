{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./.dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@mionkit/core": ["../core/index.ts"],
      "@mionkit/server-pure-functions": ["../server-pure-functions/index.ts"],
      "virtual:mion-pure-functions": ["./types/virtual-module.d.ts"]
    },
    "types": ["vitest/globals", "node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".dist"]
}
