{
  "name": "@mionkit/server-pure-functions",
  "version": "0.7.2",
  "description": "Vite plugin for client-defined, server-executed pure mapping functions in mion",
  "type": "module",
  "keywords": [
    "typescript",
    "vite",
    "plugin",
    "pure-functions",
    "server",
    "mion"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./.dist/esm/index.d.ts",
      "import": "./.dist/esm/index.js",
      "require": "./.dist/cjs/index.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite build --watch",
    "dev:test": "vitest",
    "lint": "npx --node-options='--experimental-strip-types' eslint --flag unstable_native_nodejs_ts_config src",
    "format": "prettier --write src/**/*.ts",
    "build": "vite build",
    "build-ts-dts": "tsc --project tsconfig.json --emitDeclarationOnly --declaration --skipLibCheck --outDir .dist/esm",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@mionkit/core": "^0.7.2"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
