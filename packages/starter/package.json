{
  "name": "@mionkit/starter",
  "version": "0.7.2",
  "type": "module",
  "description": "CLI to scaffold mion into meta-framework projects",
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "mion",
    "scaffold",
    "cli",
    "nextjs"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "bin": {
    "mion-starter": "./.dist/esm/cli/index.js"
  },
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./.dist/esm/index.d.ts",
      "require": "./.dist/cjs/index.cjs",
      "default": "./.dist/esm/index.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist",
    "starters"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite build --watch",
    "dev:test": "vitest watch",
    "lint": "npx eslint cli",
    "format": "prettier --write cli/**/*.ts",
    "prebuild": "node scripts/copy-starters.js",
    "build": "vite build",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "dependencies": {},
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  }
}
