{
  "name": "@mionkit/devtools",
  "version": "0.8.0-alpha.0",
  "description": "Development tooling for mion (ESLint plugin, Vite plugin, and AOT codegen).",
  "type": "module",
  "keywords": [
    "typescript",
    "eslint",
    "vite",
    "plugin",
    "codegen",
    "AOT",
    "mion"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./build/eslint/esm/index.d.ts",
      "import": "./build/eslint/esm/index.js",
      "require": "./build/eslint/cjs/index.js"
    },
    "./eslint": {
      "types": "./build/eslint/esm/index.d.ts",
      "import": "./build/eslint/esm/index.js",
      "require": "./build/eslint/cjs/index.js"
    },
    "./vite-plugin": {
      "types": "./build/vite-plugin/esm/src/vite-plugin/index.d.ts",
      "import": "./build/vite-plugin/esm/index.js",
      "require": "./build/vite-plugin/cjs/index.js"
    },
    "./codegen": {
      "types": "./src/codegen/cli-build-aot.ts",
      "import": "./build/codegen/esm/index.js",
      "require": "./build/codegen/cjs/index.js"
    }
  },
  "directories": {
    "lib": "build"
  },
  "files": [
    "build",
    "src/codegen",
    "mion-aot-template",
    "bin"
  ],
  "bin": {
    "mion-init-aot": "./bin/mion-init-aot.js",
    "mion-build-aot": "./bin/mion-build-aot.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "npm run build:eslint && npm run build:vite-plugin -- --watch",
    "dev:test": "vitest watch",
    "lint": "npx eslint src index.ts",
    "format": "prettier --write index.ts src/**/*.ts",
    "build": "npm run build:aot-template && npm run build:eslint && npm run build:vite-plugin && npm run build:codegen",
    "build:eslint": "vite build --config vite.eslint.config.ts",
    "build:vite-plugin": "vite build --config vite.vite-plugin.config.ts",
    "build:codegen": "vite build --config vite.codegen.config.ts",
    "build:aot-template": "cd mion-aot-template && npm run build",
    "build-ts-dts": "echo 'noop: devtools uses custom build'",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@deepkit/type-compiler": "^1.0.1-alpha.157",
    "@mionkit/core": "^0.7.2",
    "@mionkit/router": "^0.7.2",
    "@mionkit/run-types": "^0.7.2",
    "@rollup/pluginutils": "^5.1.0",
    "@typescript-eslint/utils": "^8.17.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": false
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@typescript-eslint/rule-tester": "^8.17.0",
    "typescript": "^5.0.0"
  }
}
