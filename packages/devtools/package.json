{
  "name": "@mionkit/devtools",
  "version": "0.8.0-alpha.0",
  "description": "Development tooling for mion (ESLint plugin and Vite plugin).",
  "type": "module",
  "keywords": [
    "typescript",
    "eslint",
    "vite",
    "plugin",
    "codegen",
    "AOT",
    "mion"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./build/eslint/esm/index.d.ts",
      "import": "./build/eslint/esm/index.js",
      "require": "./build/eslint/cjs/index.js"
    },
    "./eslint": {
      "types": "./build/eslint/esm/index.d.ts",
      "import": "./build/eslint/esm/index.js",
      "require": "./build/eslint/cjs/index.js"
    },
    "./vite-plugin": {
      "types": "./build/vite-plugin/esm/src/vite-plugin/index.d.ts",
      "import": "./build/vite-plugin/esm/index.js",
      "require": "./build/vite-plugin/cjs/index.js"
    }
  },
  "directories": {
    "lib": "build"
  },
  "files": [
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "npm run build:eslint && npm run build:vite-plugin -- --watch",
    "dev:test": "vitest watch",
    "lint": "npx eslint src index.ts",
    "format": "prettier --write index.ts src/**/*.ts",
    "build": "npm run build:eslint && npm run build:vite-plugin",
    "build:eslint": "vite build --config vite.eslint.config.ts",
    "build:vite-plugin": "vite build --config vite.vite-plugin.config.ts",
    "build-ts-dts": "echo 'noop: devtools uses custom build'",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@deepkit/type-compiler": "^1.0.1-alpha.157",
    "@rollup/pluginutils": "^5.1.0",
    "@typescript-eslint/utils": "^8.17.0",
    "vite-node": "^3.2.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": false
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@typescript-eslint/rule-tester": "^8.17.0",
    "typescript": "^5.0.0"
  }
}
