{
  "name": "@mionjs/devtools",
  "version": "0.8.2-alpha.0",
  "description": "Development tooling for mion (ESLint plugin and Vite plugin).",
  "type": "module",
  "keywords": [
    "typescript",
    "eslint",
    "vite",
    "plugin",
    "codegen",
    "AOT",
    "mion"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "exports": {
    ".": {
      "source": "./src/eslint/index.ts",
      "types": "./build/eslint/esm/index.d.ts",
      "import": "./build/eslint/esm/index.js",
      "require": "./build/eslint/cjs/index.cjs"
    },
    "./eslint": {
      "source": "./src/eslint/index.ts",
      "types": "./build/eslint/esm/index.d.ts",
      "import": "./build/eslint/esm/index.js",
      "require": "./build/eslint/cjs/index.cjs"
    },
    "./vite-plugin": {
      "source": "./src/vite-plugin/index.ts",
      "types": "./build/vite-plugin/esm/src/vite-plugin/index.d.ts",
      "import": "./build/vite-plugin/esm/index.js",
      "require": "./build/vite-plugin/cjs/index.cjs"
    },
    "./virtual-modules": {
      "types": "./src/vite-plugin/virtual-modules.d.ts"
    }
  },
  "directories": {
    "lib": "build"
  },
  "files": [
    "build",
    "src/vite-plugin/virtual-modules.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "npm run build:eslint && npm run build:vite-plugin -- --watch",
    "dev:test": "vitest watch",
    "lint": "npx eslint src",
    "format": "prettier --write src/**/*.ts",
    "build": "npm run build:eslint && npm run build:vite-plugin && npm run clean:aot-caches",
    "clean:aot-caches": "find .. -name mion-aot-cache.json -path '*/node_modules/.vite/*' -delete 2>/dev/null; true",
    "build:eslint": "vite build --config vite.eslint.config.ts",
    "build:vite-plugin": "vite build --config vite.vite-plugin.config.ts",
    "clean": "rimraf .dist && rimraf .coverage && npm run clean:aot-caches",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@deepkit/type-compiler": "1.0.19",
    "@rollup/pluginutils": "^5.1.0",
    "@typescript-eslint/utils": "^8.17.0",
    "vite-node": "^5.3.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "vite": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": false
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "^8.17.0"
  }
}
