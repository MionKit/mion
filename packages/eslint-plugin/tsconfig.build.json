{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "noImplicitAny": false,
    "removeComments": true,
    "noLib": false,
    "strict": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2020",
    "lib": ["es6", "ES2023"],
    "outDir": "build/cjs",
    "sourceMap": false,
    "declaration": false,
    "isolatedModules": true
  },
  "include": ["lib"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
