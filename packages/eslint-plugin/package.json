{
  "name": "@mionkit/eslint-plugin",
  "version": "0.8.0-alpha.0",
  "description": "ESLint rules for mion projects",
  "keywords": [
    "eslint",
    "mion",
    "runtypes",
    "run types",
    "run-type"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "type": "module",
  "main": "build/esm/index.js",
  "module": "build/esm/index.js",
  "types": "build/esm/index.d.ts",
  "directories": {
    "lib": "build"
  },
  "files": [
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite build --watch",
    "dev:test": "vitest watch",
    "lint": "npx --node-options='--experimental-strip-types' eslint --flag unstable_native_nodejs_ts_config src",
    "format": "prettier --write src/**/*.ts",
    "build": "vite build",
    "build-ts-dts": "echo 'noop: eslint-plugin is pre-built'",
    "clean": "rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.17.0"
  }
}
