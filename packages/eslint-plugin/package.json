{
  "name": "@mionkit/eslint-plugin",
  "version": "0.7.2",
  "description": "ESLint rules for mion projects",
  "keywords": [
    "eslint",
    "mion",
    "runtypes",
    "run types",
    "run-type"
  ],
  "author": "ma jerez <jerez.m82@gmail.com>",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "main": "build/cjs/index.js",
  "module": "build/esm/index.js",
  "types": "build/esm/index.d.ts",
  "directories": {
    "lib": "build"
  },
  "files": [
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "scripts": {
    "test": "jest",
    "dev": "rimraf build && tsc --build tsconfig.json --watch",
    "dev:test": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "build:cjs": "tsc --project tsconfig.build.json --module CommonJS --outDir build/cjs",
    "build:esm": "tsc --project tsconfig.build.json --module ESNext --outDir build/esm",
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "auto-readme": "embedme **/*.md && prettier --write **/*.md",
    "clean": "rimraf .coverage",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.17.0"
  }
}
