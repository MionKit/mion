    {"path": "../../../packages/bun"},
    {"path": "../../../packages/cli"},
    {"path": "../../../packages/codegen"},
    {"path": "../../../packages/eslint-plugin"},
    {"path": "../../../packages/quick-start"}
  ],
  "reflection": true,
  "include": ["."],
  "exclude": ["node_modules", ".dist"]
}
