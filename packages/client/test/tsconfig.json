{
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "compilerOptions": {
    "target": "es2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "isolatedModules": false,
    "lib": ["es6", "ES2023"],
    "baseUrl": "../../../",
    "paths": {
      "@mionkit/router": ["packages/router"],
      "@mionkit/router/*": ["packages/router/*"],
      "@mionkit/http": ["packages/http"],
      "@mionkit/http/*": ["packages/http/*"],
      "@mionkit/core": ["packages/core"],
      "@mionkit/core/*": ["packages/core/*"],
      "@mionkit/run-types": ["packages/run-types"],
      "@mionkit/run-types/*": ["packages/run-types/*"],
      "@mionkit/type-formats": ["packages/formats"],
      "@mionkit/type-formats/*": ["packages/formats/*"],
      "@mionkit/client": ["packages/client"],
      "@mionkit/client/*": ["packages/client/*"]
    }
  },
  "reflection": true,
  "include": ["."],
  "exclude": ["node_modules", ".dist"]
}
