{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": ".dist/cjs",
    "lib": ["es6", "ES2023", "DOM"],
    "composite": true,
    "rootDir": "."
  },
  "references": [
    {"path": "../core/tsconfig.cjs.json"},
    {"path": "../run-types/tsconfig.cjs.json"},
    {"path": "../http/tsconfig.cjs.json"}
  ],
  "reflection": ["src/**/*.routes.ts"],
  "include": ["."],
  "exclude": ["node_modules", "**/*.spec.ts", "**/*.test.ts", "examples", ".dist"]
}
