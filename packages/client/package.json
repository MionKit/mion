{
  "name": "@mionjs/client",
  "version": "0.8.10",
  "type": "module",
  "description": "Browser client for mion Apps.",
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./.dist/esm/index.d.ts",
      "require": "./.dist/cjs/index.cjs",
      "default": "./.dist/esm/index.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist",
    "index.ts",
    "src",
    "!src/**/*.spec.ts",
    "!src/**/*.test.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite build --watch",
    "dev:test": "vitest watch",
    "lint": "eslint src",
    "format": "prettier --write src/**/*.ts",
    "build": "vite build",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "pnpm run clean && rimraf node_modules",
    "run-test-server": "ts-node --project test/tsconfig.json test/test-server.ts"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "gitHead": "afd6e1d61525b4bf11bb84b3f85089038d70062d",
  "devDependencies": {
    "@mionjs/devtools": "workspace:*",
    "@mionjs/platform-node": "workspace:*",
    "@mionjs/router": "workspace:*",
    "@mionjs/test-server": "workspace:*",
    "@mionjs/type-formats": "workspace:*",
    "jest-environment-jsdom": "29.7.0"
  },
  "dependencies": {
    "@mionjs/core": "workspace:*",
    "@mionjs/run-types": "workspace:*"
  }
}
