{
  "name": "@mionkit/client-aot",
  "version": "0.7.2",
  "description": "AOT (Ahead-of-Time) compiled caches for @mionkit/client. Provides pre-compiled JIT and pure functions for optimal runtime performance.",
  "isMionAOT": true,
  "keywords": [
    "typescript",
    "AOT",
    "ahead-of-time",
    "compilation",
    "cache",
    "mion",
    "client"
  ],
  "author": "ma jerez <jerez.m82@gmail.com>",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./build/esm/index.d.ts",
      "require": "./build/cjs/index.js",
      "default": "./build/esm/index.js"
    }
  },
  "directories": {
    "lib": "build"
  },
  "files": [
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:aot": "npx mion-build-aot --dir . --start-server-script ./src/init.ts",
    "clean": "rimraf build"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "peerDependencies": {
    "@mionkit/core": "^0.7.2",
    "@mionkit/codegen": "^0.7.2"
  }
}
