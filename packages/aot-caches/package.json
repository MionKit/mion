{
  "name": "@mionkit/aot-caches",
  "version": "0.7.2",
  "description": "Template package for mion AOT (Ahead-of-Time) cache generation. This package provides pre-built cache files and loading functionality.",
  "isMionAOT": true,
  "keywords": [
    "typescript",
    "AOT",
    "ahead-of-time",
    "compilation",
    "cache",
    "template",
    "mion"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "main": "./build/cjs/src/index.js",
  "types": "./build/cjs/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/esm/src/index.d.ts",
      "require": "./build/cjs/src/index.js",
      "default": "./build/esm/src/index.js"
    }
  },
  "directories": {
    "lib": "build"
  },
  "files": [
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npx ts-node -r tsconfig-paths/register --project ../codegen/tsconfig.json ../codegen/src/run-build-aot.ts --dir . --start-server-script ./defaultRoutes.ts",
    "build-ts-dts": "echo 'noop: aot-caches uses codegen build'"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "devDependencies": {
    "@mionkit/core": "^0.7.2",
    "@mionkit/router": "^0.7.2"
  }
}
