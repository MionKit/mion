{
  "name": "@mionjs/platform-gcloud",
  "version": "0.8.10",
  "type": "module",
  "description": "Google Cloud functions wrapper for mion router.",
  "keywords": [
    "typescript",
    "API",
    "RPC",
    "json",
    "schema",
    "generate",
    "server",
    "serverless",
    "framework",
    "node"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./.dist/esm/index.d.ts",
      "require": "./.dist/cjs/index.cjs",
      "default": "./.dist/esm/index.js"
    }
  },
  "directories": {
    "lib": ".dist"
  },
  "files": [
    ".dist",
    "index.ts",
    "src",
    "!src/**/*.spec.ts",
    "!src/**/*.test.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/mion.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite build --watch",
    "dev:test": "vitest watch",
    "lint": "eslint src",
    "format": "prettier --write src/**/*.ts",
    "build": "vite build",
    "clean": "rimraf .dist & rimraf .coverage",
    "fresh-start": "pnpm run clean && rimraf node_modules"
  },
  "bugs": {
    "url": "https://github.com/MionKit/mion/issues"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "3.5.1",
    "@mionjs/core": "workspace:*",
    "@mionjs/router": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "4.17.25"
  },
  "gitHead": "afd6e1d61525b4bf11bb84b3f85089038d70062d"
}
