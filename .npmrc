# ─────────────────────────────────────────────────────────
# Mion monorepo — pnpm security-hardened configuration
# ─────────────────────────────────────────────────────────
# This file is read by pnpm. Do NOT install with npm — see CLAUDE.md.

# ── Lockfile / install integrity ─────────────────────────
# Refuse to install if lockfile would be modified.
frozen-lockfile=true
prefer-frozen-lockfile=true
prefer-offline=false
verify-store-integrity=true

# ── Version pinning (no auto-bumps) ──────────────────────
# `pnpm add` writes exact versions, never ^ or ~.
save-exact=true
save-prefix=
save-workspace-protocol=rolling
resolution-mode=highest

# ── Supply-chain protection: minimum release age ─────────
# Refuse to install package versions younger than 30 days.
# Defeats fast-spreading malicious releases (TanStack-style).
minimum-release-age=43200
minimum-release-age-exclude=

# ── Block lifecycle scripts (preinstall/install/postinstall) ─
# Hard-block ALL build scripts. Specific packages can be
# re-enabled via `pnpm.onlyBuiltDependencies` in package.json.
ignore-scripts=true
side-effects-cache=false

# ── Block non-registry sources ───────────────────────────
# Refuse git/github/file/http specifiers from dependencies.
# (workspace:* is exempt — it's the workspace protocol, not external.)
registry=https://registry.npmjs.org/
allow-non-registry-protocols=false

# ── Strict peer / hoisting ───────────────────────────────
strict-peer-dependencies=true
auto-install-peers=false
# Use npm-like flat hoisting so transitive deps (esbuild, etc.) remain
# accessible from sibling packages without each one needing to redeclare
# them. Security is enforced by the lockfile + minimum-release-age +
# ignore-scripts settings above, NOT by the linker layout.
node-linker=hoisted

# ── Misc hardening ───────────────────────────────────────
fund=false
audit=false
loglevel=warn
