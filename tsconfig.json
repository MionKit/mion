{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "noImplicitAny": false,
    "removeComments": true,
    "noLib": false,
    "strict": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2020",
    "lib": ["es6", "ES2023"],
    "outDir": ".dist/cjs",
    "composite": true,
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "sourceMap": false,
    "isolatedModules": true,
    "rewriteRelativeImportExtensions": true,
    "paths": {
      "@mionkit/*": ["packages/*"]
    }
  },
  "references": [
    {"path": "./packages/core"},
    {"path": "./packages/run-types"},
    {"path": "./packages/formats"},
    {"path": "./packages/router"},
    {"path": "./packages/client"},
    {"path": "./packages/http"},
    {"path": "./packages/aws"},
    {"path": "./packages/gcloud"},
    {"path": "./packages/bun"},
    {"path": "./packages/cli"},
    {"path": "./packages/eslint-plugin"},
    {"path": "./packages/quick-start"}
  ],
  "files": [],
  "exclude": ["node_modules", ".dist"],
  "reflection": true
}
