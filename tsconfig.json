{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "noImplicitAny": false,
    "removeComments": true,
    "noLib": false,
    "strict": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2020",
    "lib": ["es6", "ES2023"],
    "outDir": ".dist/cjs",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "incremental": true,
    "sourceMap": true,
    "paths": {
      "@mionkit/core/*": ["packages/core/src/*"],
      "@mionkit/run-types/*": ["packages/run-types/src/*"],
      "@mionkit/formats/*": ["packages/formats/src/*"],
      "@mionkit/router/*": ["packages/router/src/*"],
      "@mionkit/*": ["packages/*"]
    }
  },
  "references": [
    {"path": "./packages/core"},
    {"path": "./packages/common"},
    {"path": "./packages/run-types"},
    {"path": "./packages/formats"},
    {"path": "./packages/router"},
    {"path": "./packages/client"},
    {"path": "./packages/http"},
    {"path": "./packages/aws"},
    {"path": "./packages/gcloud"},
    {"path": "./packages/bun"},
    {"path": "./packages/cli"},
    {"path": "./packages/codegen"},
    {"path": "./packages/eslint-plugin"},
    {"path": "./packages/quick-start"}
  ],
  "files": [],
  "exclude": ["node_modules", ".dist"],
  "reflection": true
}
