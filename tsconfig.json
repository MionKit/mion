{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "noImplicitAny": false,
    "removeComments": true,
    "noLib": false,
    "strict": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "outDir": ".dist/cjs",
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "incremental": true,
    "sourceMap": true,
    "isolatedModules": true,
    "rewriteRelativeImportExtensions": true,
    "paths": {
      "@mionjs/*": ["packages/*"]
    }
  },
  "references": [
    {"path": "./packages/core"},
    {"path": "./packages/run-types"},
    {"path": "./packages/type-formats"},
    {"path": "./packages/router"},
    {"path": "./packages/client"},
    {"path": "./packages/platform-node"},
    {"path": "./packages/platform-aws"},
    {"path": "./packages/platform-gcloud"},
    {"path": "./packages/platform-bun"},
    {"path": "./packages/devtools"},
    {"path": "./packages/test-server"}
  ],
  "files": [],
  "exclude": ["node_modules", ".dist"],
  "reflection": true
}
