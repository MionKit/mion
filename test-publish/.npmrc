# ─────────────────────────────────────────────────────────
# test-publish — pnpm security-hardened configuration
# ─────────────────────────────────────────────────────────
# This package consumes mion via local tarballs (file:./tarballs/*.tgz).
# It MUST allow file: protocol — that's the whole point of this package.

# ── Lockfile / install integrity ─────────────────────────
# NOT frozen-lockfile: tarballs get repacked frequently, lockfile churns.
prefer-frozen-lockfile=false
verify-store-integrity=true

# ── Version pinning ──────────────────────────────────────
save-exact=true
save-prefix=
resolution-mode=highest

# ── Supply-chain protection: minimum release age ─────────
minimum-release-age=43200
# Exempt @mionjs/* — those come from local tarballs anyway.
minimum-release-age-exclude=@mionjs/*

# ── Block lifecycle scripts ──────────────────────────────
ignore-scripts=true

# ── Allow file: protocol (required for tarball consumption) ─
allow-non-registry-protocols=true
registry=https://registry.npmjs.org/

# ── Strict peer / hoisting ───────────────────────────────
strict-peer-dependencies=false
auto-install-peers=false
node-linker=isolated

# ── Misc hardening ───────────────────────────────────────
fund=false
audit=false
loglevel=warn
