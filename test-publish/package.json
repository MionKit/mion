{
  "name": "@mionjs/test-publish",
  "version": "0.7.2",
  "private": true,
  "type": "module",
  "description": "Build verification tests - validates that all mion packages work correctly after being built",
  "keywords": [
    "mion",
    "build",
    "tests",
    "verification",
    "e2e"
  ],
  "author": "ma jerez",
  "homepage": "https://mion.io/",
  "license": "MIT",
  "scripts": {
    "test": "echo 'Run verify to test built artifacts'",
    "verify": "npm run test:build-verification && npm run test:pure-functions",
    "test:build-verification": "vitest run",
    "test:pure-functions": "cd packages/pure-functions-test && vitest run",
    "dev:test": "vitest watch",
    "lint": "npx eslint packages/modules/src",
    "format": "prettier --write packages/modules/src/**/*.ts",
    "build": "tsc --project tsconfig.json",
    "clean": "rimraf .dist",
    "fresh-start": "npm run clean && rimraf node_modules"
  },
  "dependencies": {
    "@mionjs/platform-aws": "file:../packages/platform-aws",
    "@mionjs/platform-bun": "file:../packages/platform-bun",
    "@mionjs/client": "file:../packages/client",
    "@mionjs/core": "file:../packages/core",
    "@mionjs/platform-gcloud": "file:../packages/platform-gcloud",
    "@mionjs/platform-node": "file:../packages/platform-node",
    "@mionjs/router": "file:../packages/router",
    "@mionjs/run-types": "file:../packages/run-types",
    "@mionjs/test-server": "file:../packages/test-server",
    "@mionjs/type-formats": "file:../packages/type-formats"
  },
  "devDependencies": {
    "dom-storage": "^2.1.0",
    "@mionjs/devtools": "file:../packages/devtools"
  }
}
