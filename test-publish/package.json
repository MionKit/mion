{
  "name": "@mionjs/test-publish",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "E2E verification - simulates a real project consuming mion packages from npm tarballs",
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "build": "vite build --config vite.build.config.ts",
    "test:aot": "vitest run --config vitest.aot.config.ts",
    "verify": "npm run test && npm run build && npm run test:aot",
    "clean": "rimraf dist node_modules"
  },
  "dependencies": {
    "@mionjs/core": "file:./tarballs/mionjs-core.tgz",
    "@mionjs/run-types": "file:./tarballs/mionjs-run-types.tgz",
    "@mionjs/router": "file:./tarballs/mionjs-router.tgz",
    "@mionjs/platform-node": "file:./tarballs/mionjs-platform-node.tgz",
    "@mionjs/client": "file:./tarballs/mionjs-client.tgz",
    "@mionjs/type-formats": "file:./tarballs/mionjs-type-formats.tgz"
  },
  "devDependencies": {
    "@mionjs/devtools": "file:./tarballs/mionjs-devtools.tgz",
    "dom-storage": "^2.1.0",
    "vitest": "^4.0.18",
    "vite": "^7.3.1",
    "typescript": "5.9.3",
    "rimraf": "^6.1.3",
    "eslint": "^9.20.1",
    "@eslint/js": "^9.20.1",
    "typescript-eslint": "^8.30.1"
  }
}
