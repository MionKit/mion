{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "noImplicitAny": false,
    "removeComments": true,
    "noLib": false,
    "strict": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "outDir": ".dist",
    "rootDir": "packages/modules/src",
    "declaration": false,
    "sourceMap": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["packages/modules/src/**/*.ts"],
  "exclude": ["node_modules", ".dist"]
}
