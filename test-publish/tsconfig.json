{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "noImplicitAny": false,
    "strict": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "sourceMap": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["@mionjs/devtools/virtual-modules"]
  },
  "reflection": true,
  "include": ["src/**/*.ts", "globalSetup.ts"],
  "exclude": ["node_modules", "dist", "tarballs"]
}
