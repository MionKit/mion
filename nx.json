{
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default",
      "options": {
        "cacheableOperations": ["test", "lint", "format", "build"]
      }
    }
  },
  "targetDefaults": {
    "lint": {
      "dependsOn": []
    },
    "test": {
      "dependsOn": ["@mionjs/client:test"],
      "outputs": ["{workspaceRoot}/.coverage"]
    },
    "build": {
      "dependsOn": ["lint", "^build"],
      "outputs": ["{projectRoot}/.dist"]
    },
    "clean": {
      "dependsOn": []
    }
  },
  "defaultBase": "master",
  "release": {
    "projects": ["packages/*", "!packages/test-publish", "!packages/test-server"]
  }
}
